# Global switch — flip to "live" once all keys below are set, or override per-vendor
# with e.g. GEMINI_MODE=live while keeping the rest mocked.
INTEGRATION_MODE=mock

# AgentPhone (inbound call entry point — required for the demo)
AGENTPHONE_API_KEY=
AGENTPHONE_NUMBER=
AGENTPHONE_WEBHOOK_SECRET=
AGENTPHONE_AGENT_ID=

# Google Gemini (orchestration brain)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# Supermemory (shared memory layer)
SUPERMEMORY_API_KEY=
SUPERMEMORY_PROJECT_ID=

# Moss — sub-10ms semantic search runtime (@inferedge/moss)
MOSS_PROJECT_ID=
MOSS_PROJECT_KEY=
MOSS_CONTRACTORS_INDEX=cma_contractors_v1
MOSS_KNOWLEDGE_INDEX=cma_knowledge_v1

# Browser Use (contractor sourcing — Cloud API v3)
BROWSERUSE_API_KEY=
BROWSERUSE_BASE_URL=https://api.browser-use.com/api/v3

# Sponge (payments)
SPONGE_API_KEY=
SPONGE_ACCOUNT_ID=

# AgentMail (notifications + invoices)
AGENTMAIL_API_KEY=
AGENTMAIL_INBOX=
